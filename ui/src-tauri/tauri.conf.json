{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lan-clip",
  "version": "1.0.0",
  "identifier": "com.lianghao.lan-clip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "lan-clip",
        "width": 900,
        "height": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../target/lan-clip-1.0-standalone.jar": "lan-clip-1.0-standalone.jar"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/lhing17/lan-clip/releases/latest/download/latest.json"
      ],
      "pubkey": "3lj1Q6tWNklflJR+dS4vdt4i5DbxL6I6KdjNGiaF/mU="
    }
  }
}
